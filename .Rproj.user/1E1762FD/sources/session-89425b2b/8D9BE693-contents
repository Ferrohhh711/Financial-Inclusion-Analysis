library(janitor)

# 1. Prepare data for modeling (convert Yes/No to 1/0)
df_model <- df_clean %>%
  mutate(across(everything(), ~ ifelse(. == "Yes", 1, 0)))

# 2. Fit the Logistic Regression Model
# Logic: Does internet access and remittances predict saving behavior?
logit_model <- glm(saved ~ internetaccess + remittances, 
                   data = df_model, 
                   family = binomial(link = "logit"))

# 3. View the Professional Summary
summary(logit_model)

# 4. Get "Clean" Coefficients (Odds Ratios) for your GitHub
library(broom)
tidy_output <- tidy(logit_model, conf.int = TRUE, exponentiate = TRUE)
print(tidy_output)
